{
  "version": 2,
  "projects": {
    "core-browser": {
      "root": "libs/core/browser",
      "sourceRoot": "libs/core/browser/src",
      "projectType": "library",
      "tags": [],
      "targets": {
        "build": {
          "executor": "@nrwl/web:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/core/browser",
            "tsConfig": "libs/core/browser/tsconfig.lib.json",
            "project": "libs/core/browser/package.json",
            "entryFile": "libs/core/browser/src/index.ts",
            "external": ["react/jsx-runtime"],
            "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
            "assets": [
              {
                "glob": "libs/core/browser/README.md",
                "input": ".",
                "output": "."
              }
            ]
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["libs/core/browser/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/core/browser"],
          "options": {
            "jestConfig": "libs/core/browser/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "core-data": {
      "root": "libs/core/data",
      "sourceRoot": "libs/core/data/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["libs/core/data/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/core/data"],
          "options": {
            "jestConfig": "libs/core/data/jest.config.js",
            "passWithNoTests": true
          }
        },
        "build": {
          "executor": "@nrwl/node:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/core/data",
            "tsConfig": "libs/core/data/tsconfig.lib.json",
            "packageJson": "libs/core/data/package.json",
            "main": "libs/core/data/src/index.ts",
            "assets": ["libs/core/data/*.md"]
          }
        }
      },
      "tags": []
    },
    "core-theme": {
      "root": "libs/core/theme",
      "sourceRoot": "libs/core/theme/src",
      "projectType": "library",
      "tags": [],
      "targets": {
        "build": {
          "executor": "@nrwl/web:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/core/theme",
            "tsConfig": "libs/core/theme/tsconfig.lib.json",
            "project": "libs/core/theme/package.json",
            "entryFile": "libs/core/theme/src/styles.scss",
            "external": ["react/jsx-runtime"],
            "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
            "assets": [
              {
                "glob": "libs/core/theme/README.md",
                "input": ".",
                "output": "."
              }
            ]
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["libs/core/theme/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/core/theme"],
          "options": {
            "jestConfig": "libs/core/theme/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "react": {
      "root": "libs/react",
      "sourceRoot": "libs/react/src",
      "projectType": "library",
      "targets": {
        "build": {
          "executor": "@nrwl/web:package",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/libs/react",
            "tsConfig": "libs/react/tsconfig.lib.json",
            "project": "libs/react/package.json",
            "entryFile": "libs/react/src/index.ts",
            "external": ["react/jsx-runtime"],
            "rollupConfig": "@nrwl/react/plugins/bundle-rollup",
            "assets": [
              {
                "glob": "libs/react/README.md",
                "input": ".",
                "output": "."
              }
            ]
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["libs/react/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/react"],
          "options": {
            "jestConfig": "libs/react/jest.config.js",
            "passWithNoTests": true
          }
        }
      },
      "tags": []
    },
    "react-test-app": {
      "root": "apps/react-test-app",
      "sourceRoot": "apps/react-test-app/src",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/web:build",
          "outputs": ["{options.outputPath}"],
          "defaultConfiguration": "production",
          "options": {
            "outputPath": "dist/apps/react-test-app",
            "index": "apps/react-test-app/src/index.html",
            "baseHref": "/",
            "main": "apps/react-test-app/src/main.tsx",
            "polyfills": "apps/react-test-app/src/polyfills.ts",
            "tsConfig": "apps/react-test-app/tsconfig.app.json",
            "assets": [
              "apps/react-test-app/src/favicon.ico",
              "apps/react-test-app/src/assets"
            ],
            "styles": ["apps/react-test-app/src/styles.scss"],
            "scripts": [],
            "webpackConfig": "@nrwl/react/plugins/webpack"
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/react-test-app/src/environments/environment.ts",
                  "with": "apps/react-test-app/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false
            }
          }
        },
        "serve": {
          "executor": "@nrwl/web:dev-server",
          "options": {
            "buildTarget": "react-test-app:build",
            "hmr": true
          },
          "configurations": {
            "production": {
              "buildTarget": "react-test-app:build:production",
              "hmr": false
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["apps/react-test-app/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/react-test-app"],
          "options": {
            "jestConfig": "apps/react-test-app/jest.config.js",
            "passWithNoTests": true
          }
        }
      },
      "tags": []
    },
    "react-test-app-e2e": {
      "root": "apps/react-test-app-e2e",
      "sourceRoot": "apps/react-test-app-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/react-test-app-e2e/cypress.json",
            "devServerTarget": "react-test-app:serve",
            "tsConfig": "apps/react-test-app-e2e/tsconfig.json"
          },
          "configurations": {
            "production": {
              "devServerTarget": "react-test-app:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "outputs": ["{options.outputFile}"],
          "options": {
            "lintFilePatterns": ["apps/react-test-app-e2e/**/*.{js,ts}"]
          }
        }
      },
      "tags": [],
      "implicitDependencies": ["react-test-app"]
    }
  }
}
