  "license": "MIT",
  "scripts": {
    "start": "nx serve --port=4050",
    "build": "nx build",
    "build:all": "npm run docs:react && nx run-many --all --target=build --parallel --buildableProjectDepsInPackageJsonType=dependencies --skip-nx-cache && nx workspace-generator fix-lib-output",
    "test": "nx test",
    "test:all": "nx run-many --all --target=test --parallel --skip-nx-cache",
    "clean:modules": "npx rimraf node_modules",
    "clean:dist": "npx rimraf dist",
    "docs:react": "npx react-docgen -o ./react-docgen-output.json ./libs/react/src/**/*.tsx --pretty && npx ts-node ./scripts/gen-md-from-react-docgen.script.ts ./react-docgen-output.json ./libs/react/README && npx rimraf ./react-docgen-output.json"
  },
